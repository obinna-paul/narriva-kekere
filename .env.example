DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
PAYSTACK_SECRET_KEY=
# Next.js only exposes env vars prefixed NEXT_PUBLIC_ to the browser — the
# Paystack public key is safe to expose (it's not the secret key), but it
# needs this prefix to reach the client-side checkout popup.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
# Story cover images and user avatars are served from Cloudinary's CDN
# (src/lib/storage/cloudinary.ts, cloudinary-urls.ts) — without all three of
# these set on the deployed environment, every cover/avatar URL 404s.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Used by src/lib/audio/generate.ts (OpenAI TTS, tts-1-hd/nova) to generate
# story narration audio at publish time — see Phase B6.
OPENAI_API_KEY=
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
CRON_SECRET=
