DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
PAYSTACK_SECRET_KEY=
# Next.js only exposes env vars prefixed NEXT_PUBLIC_ to the browser — the
# Paystack public key is safe to expose (it's not the secret key), but it
# needs this prefix to reach the client-side checkout popup.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
