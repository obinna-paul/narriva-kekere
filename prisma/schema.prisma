// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shared across Narriva and Kekere — one account, one login, both brands.
// See README.md "Brand independence rule" before adding anything here that
// implies a product link between the two brands.

enum UserRole {
  READER
  WRITER
  ADMIN
}

enum AccountStatus {
  CLAIMED
  UNCLAIMED
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  name     String
  password String?
  role     UserRole @default(READER)
  avatar   String?
  bio      String?

  // Author-facing profile fields, used when this user is a published Narriva
  // author (role WRITER) and shown on /authors/[slug] — see Phase 3/7.
  slug         String? @unique
  shortBio     String?
  avatarColor  String?
  socialLinks  Json?

  emailVerified                DateTime?
  emailVerificationCode        String?
  emailVerificationExpiresAt   DateTime?

  // Password reset — one-time token hashed with SHA-256, expires in 1 hour.
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?

  // Legal consent timestamp and account deletion flow — built out in Phase 16.
  termsAcceptedAt     DateTime?
  deletionRequestedAt DateTime?

  // Referral system — each user gets a unique code on signup.
  // `referredBy` stores the inviter's referral code (not userId), so the
  // inviter can be found even if they change their slug/name later.
  referralCode String? @unique
  referredBy   String?

  // Account suspension — admin-managed, checked in auth callback.
  suspended        Boolean   @default(false)
  suspensionReason String?
  suspendedUntil   DateTime?

  // First-story-free benefit: each new user gets their first unlock at no cost.
  freeReadUsed Boolean @default(false)

  // Pre-launch onboarding: admins create placeholder WRITER accounts and
  // author stories into them; the writer later claims via a tokenised link.
  accountStatus       AccountStatus @default(CLAIMED)
  claimToken          String?       @unique
  claimTokenExpiresAt DateTime?
  createdByAdminId    String?

  // Set on every successful sign-in (see authorize() in auth/options.ts) —
  // the only real signal of account activity. updatedAt moves on any
  // profile/admin edit too, so it isn't a substitute for this.
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet             Wallet?
  stories            Story[]             @relation("StoryAuthor")
  unlocks            StoryUnlock[]
  savedStories       SavedStory[]
  narrivaSubmissions NarrivaSubmission[]
  orders             Order[]
  bookPurchases      BookPurchase[]
  bookReadingProgress BookReadingProgress[]
  books              Book[]              @relation("BookAuthor")
  storyRatings       StoryRating[]
  storyCompletions   StoryCompletion[]
  storyReadingProgress StoryReadingProgress[]
  readingActivity      ReadingActivity[]
  authorProjects     AuthorProject[]
  tipsSent             Tip[]                 @relation("TipReader")
  tipsReceived         Tip[]                 @relation("TipWriter")
  referralCodeRecord   ReferralCode?
  referralsSent        Referral[]            @relation("ReferralsSent")
  referralReceived     Referral?             @relation("ReferralReceived")
  writerBankDetails    WriterBankDetails?
  withdrawalRequests   WithdrawalRequest[]
  deliverableComments  DeliverableComment[]
  projectMessages      ProjectMessage[]
  nariConversations    NariConversation[]
  kekereContracts      KekereContract[]
  notifications        Notification[]
  paragraphComments    ParagraphComment[]
  paragraphReactions   ParagraphReaction[]
}

enum NotificationType {
  STORY_SUBMITTED
  STORY_APPROVED
  STORY_REVISIONS_REQUESTED
  STORY_REJECTED
  CONTRACT_RECEIVED
  COMPETITION_RESULT
  REFERRAL_REWARD_EARNED
  REFERRAL_JOINED
  WITHDRAWAL_PROCESSED
  WITHDRAWAL_REJECTED
  VERSION_RESTORED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
}

model Wallet {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Cowries from top-ups, completion bonuses, and referral rewards. Used to
  // unlock stories and tip writers. Never withdrawable — always whole
  // cowries, since top-ups and story costs are both whole numbers.
  spendingBalance Int @default(0)
  // Cowries earned by writers from their 70% share of story unlocks and from
  // tips received. The withdrawable balance. Decimal because a 70/30 split
  // of a whole-cowrie story cost isn't always a whole number (e.g. a
  // 1-cowrie unlock nets the writer exactly 0.7, not 0 or 1) — carrying the
  // fraction instead of rounding it away is what actually gets writers
  // their full 70%.
  earnedBalance   Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

enum TransactionType {
  TOP_UP
  UNLOCK
  REFUND
  WITHDRAWAL
  TIP
  REFERRAL
  READ_REWARD
  COMPLETION_BONUS
  TIP_SENT
  TIP_RECEIVED
  REFERRAL_REWARD
  EARNINGS_CREDIT
  PLATFORM_EARNINGS
  // Manual admin wallet adjustments (e.g. compensating a user, correcting an
  // error) — must never share the TOP_UP type, since every revenue/conversion
  // metric filters on TOP_UP to mean "a real Paystack purchase happened."
  // A genuine business decision — counted in totalIssued.
  ADMIN_CREDIT
  ADMIN_DEBIT
  // Fixing a wallet balance that was never backed by any transaction in the
  // first place (legacy migration artifacts, direct DB edits, bugs) — never
  // a business decision, so unlike ADMIN_CREDIT/DEBIT this is deliberately
  // excluded from totalIssued. It still counts toward a wallet's own ledger
  // history, so applying one correctly resolves that wallet's
  // "untracked balance" flag.
  DATA_CORRECTION_CREDIT
  DATA_CORRECTION_DEBIT
  // A writer moving their own earned (withdrawable) cowries into their
  // spending wallet — a one-way, irreversible transfer within a single
  // user's two wallet buckets. Net-zero for the economy (like tips): the
  // OUT row debits EARNED, the paired IN row credits SPENDING, so total
  // cowries in circulation is unchanged and neither is real issuance.
  EARNED_TO_SPENDING_OUT
  EARNED_TO_SPENDING_IN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WalletField {
  SPENDING
  EARNED
}

model Transaction {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type             TransactionType
  // Decimal, not Int: EARNINGS_CREDIT rows record a writer's exact 70%
  // share, which isn't always a whole number. Whole-cowrie transaction
  // types (TOP_UP, UNLOCK, etc.) just store an integral value here, e.g. 5.00.
  amountCowries    Decimal @db.Decimal(10, 2)
  amountNgn        Float?
  paymentReference String?
  status           TransactionStatus @default(PENDING)
  description      String?
  // Which wallet bucket this transaction affected. Nullable so pre-migration
  // transactions (recorded against the old single `balance` field) don't
  // need a backfilled value.
  walletField      WalletField?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// Kekere Stories

enum StoryStatus {
  DRAFT
  SUBMITTED
  // REVIEWING and REVISIONS_REQUESTED support the moderation pipeline (Phase 12).
  REVIEWING
  REVISIONS_REQUESTED
  PUBLISHED
  REJECTED
  // Story is fully set up (content, price, tags) but waiting for the author to
  // sign the publishing contract before going live.
  PENDING_CONTRACT
}

enum StoryTier {
  STANDARD
  FEATURED
  PREMIUM
}

enum StorySource {
  STANDARD
  ADMIN_AUTHORED
}

enum AudioGenerationStatus {
  NOT_GENERATED
  GENERATING
  GENERATED
  FAILED
}

model Story {
  id       String @id @default(cuid())
  authorId String
  author   User   @relation("StoryAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  title    String
  hookLine String
  // A Tiptap document ({ type: "doc", content: [...] }) — every paragraph
  // node carries a stable attrs.id (see src/lib/tiptap/doc-utils.ts), which
  // paragraph comments/reactions (later phases) key off of. Never hand-edit;
  // always go through ensureParagraphIds() before persisting.
  body        Json
  // Bumped if the Tiptap document shape changes in a future format
  // migration — lets old rows be detected and re-migrated rather than
  // assumed to already match the current shape.
  bodyVersion Int @default(1)
  // Maintained server-side on every save (see ensureParagraphIds/countWords
  // in doc-utils.ts) — never trust a client-supplied word count.
  wordCount   Int @default(0)
  // Bumped only by a body-content save (not title/hookLine/tier-only saves)
  // — doubles as the optimistic-concurrency watermark StoryEditor's
  // conflict detection compares against, and as the autosave display
  // ("Saved 2 min ago"). Null until the first body save.
  lastSavedAt DateTime?
  // False once published — kept distinct from `status` because a
  // REVISIONS_REQUESTED story is still a draft for restore-eligibility
  // purposes (see StoryVersion restore) even though it has left DRAFT.
  isDraft     Boolean @default(true)

  // OpenAI-generated narration audio (see src/lib/audio/generate.ts) — R2
  // path, not a public URL; signed URLs are minted per-request. Triggered
  // automatically on publish, falls back to browser Web Speech API client
  // -side until/if generation completes.
  audioRef              String?
  audioGeneratedAt      DateTime?
  audioDurationSecs     Int?
  audioGenerationStatus AudioGenerationStatus @default(NOT_GENERATED)

  // Free-text genre and a placeholder cover colour — no real cover image
  // pipeline yet, same placeholder-block approach used everywhere else in
  // this codebase (Book, BlogPost). Added in Phase 11 alongside the rest of
  // Kekere's reading-side backend; didn't exist in the Phase 1 schema.
  genre      String  @default("Drama")
  coverColor String  @default("#C75D2C")
  // R2 object key for the cover image. Null until a cover is uploaded.
  // Served publicly via GET /api/kekere/story-cover/[id].
  coverImageRef String?

  isSerialized Boolean @default(false)
  chapters     Json?

  status StoryStatus @default(DRAFT)
  tier   StoryTier

  cowrieCost        Int
  readingTime       Int
  completionRate    Float?
  moderationNotes   String?
  plagiarismFlagged Boolean @default(false)
  featured          Boolean @default(false)

  sourceType        StorySource @default(STANDARD)
  authoredByAdminId String?

  // Set on the DRAFT/REVISIONS_REQUESTED → SUBMITTED transition — used to
  // order the admin moderation queue oldest-first by actual submission time,
  // not draft-creation time (createdAt) or last-edit time (updatedAt, which
  // also moves on unrelated edits while in REVISIONS_REQUESTED).
  submittedAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  unlocks            StoryUnlock[]
  competitionEntries CompetitionEntry[]
  savedBy            SavedStory[]
  ratings            StoryRating[]
  completions        StoryCompletion[]
  readingProgress    StoryReadingProgress[]
  tips               Tip[]
  platformEarnings   PlatformEarnings[]
  versions           StoryVersion[]
  paragraphComments  ParagraphComment[]
  paragraphReactions ParagraphReaction[]
  tags               StoryTag[]
  kekereContracts    KekereContract[]

  @@index([authorId])
}

// Story tagging system — tags are admin-assigned at publish time.
// The canonical tag list lives in src/content/story-tags.ts; no new
// tags can be created from the UI — slugs must match that list.
model Tag {
  id    String @id @default(cuid())
  slug  String @unique
  label String

  stories StoryTag[]

  @@index([slug])
}

model StoryTag {
  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storyId, tagId])
  @@index([storyId])
  @@index([tagId])
}

model ParagraphComment {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  // The UUID from the paragraph's attrs.id in the Tiptap doc (see
  // src/lib/tiptap/doc-utils.ts) — not a foreign key, since paragraph ids
  // live inside Story.body's JSON, not their own table.
  paragraphId String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storyId, paragraphId])
  @@index([storyId, createdAt])
}

model ParagraphReaction {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  paragraphId String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // A single emoji character from ALLOWED_REACTION_EMOJIS (see
  // src/lib/tiptap/reaction-emojis.ts) — validated at the API layer, not
  // by the database.
  emoji       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storyId, paragraphId, userId])
  @@index([storyId, paragraphId])
}

model StoryVersion {
  id            String   @id @default(cuid())
  storyId       String
  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  versionNumber Int
  // The full Tiptap document at this point in time.
  content       Json
  wordCount     Int
  label         String
  savedAt       DateTime @default(now())

  @@unique([storyId, versionNumber])
  @@index([storyId, savedAt])
}

model StoryUnlock {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId    String
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

// The following models (through SubmissionUpdate below) were found missing
// from this file — referenced by other models/relations but never defined
// — while the underlying tables still existed in the database untouched.
// Reconstructed here from a live introspection of the actual columns,
// foreign keys, and indexes so the schema matches what's really deployed.

model SavedStory {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId String
  story   Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())

  @@unique([userId, storyId])
}

model StoryRating {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId String
  story   Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  rating  Int // 1–5
  ratedAt DateTime @default(now())

  @@unique([userId, storyId])
}

model StoryCompletion {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId       String
  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  completedAt   DateTime @default(now())
  bonusCredited Boolean  @default(false)

  @@unique([userId, storyId])
}

model Tip {
  id       String   @id @default(cuid())
  readerId String
  reader   User     @relation("TipReader", fields: [readerId], references: [id], onDelete: Cascade)
  writerId String
  writer   User     @relation("TipWriter", fields: [writerId], references: [id], onDelete: Cascade)
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tippedAt DateTime @default(now())

  @@index([readerId, storyId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())
}

enum ReferralStatus {
  PENDING
  REWARDED
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  referrer       User           @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String         @unique
  referredUser   User           @relation("ReferralReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  codeUsed       String
  status         ReferralStatus @default(PENDING)
  rewardedAt     DateTime?
  createdAt      DateTime       @default(now())
}

model Book {
  id       String @id @default(cuid())
  slug     String @unique
  title    String
  authorId String
  author   User   @relation("BookAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  genre         String
  hookLine      String
  synopsis      String
  excerpt       String[]
  coverImageRef String
  price         Float
  editorNote            String?
  editorNoteAttribution String?

  ebookRef          String
  chapterCount      Int @default(0)
  wordCount         Int @default(0)
  estimatedReadTime Int @default(0) // minutes

  featured     Boolean @default(false)
  isNewRelease Boolean @default(false)

  publishedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems      OrderItem[]
  purchases       BookPurchase[]
  sales           BookSale[]
  readingProgress BookReadingProgress[]

  @@index([authorId])
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalNgn         Float
  paymentReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId  String
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  priceNgn Float

  @@index([orderId])
  @@index([bookId])
}

model BookPurchase {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  paymentReference String
  purchasedAt      DateTime @default(now())

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model BookReadingProgress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  currentChapter        Int      @default(1)
  currentScrollPosition Int      @default(0) // pixel offset within chapter
  lastReadAt            DateTime
  completedChapterIds   Int[] // chapter indices the user has finished

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model SubmissionUpdate {
  id           String            @id @default(cuid())
  submissionId String
  submission   NarrivaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  note      String
  createdAt DateTime @default(now())

  @@index([submissionId])
}

enum CompetitionStatus {
  DRAFT
  OPEN
  CLOSED
  JUDGING
  COMPLETE
}

model Competition {
  id    String @id @default(cuid())
  // Added in Phase 13 alongside the rest of the competitions backend — the
  // Phase 1 schema had no clean-URL field, and /competitions/[slug] needs one.
  slug  String @unique
  title String
  theme String
  // Longer copy for the detail page; `theme` stays the short label used on
  // listing cards. Didn't exist in the Phase 1 schema either.
  themeDescription String   @default("")
  deadline         DateTime
  prizeDescription String
  wordCountLimit   Int
  // Optional floor for competitions with a range ("1,000-1,500 words")
  // rather than a single ceiling. Null means no minimum is enforced.
  wordCountMin     Int?
  status           CompetitionStatus @default(DRAFT)
  createdAt        DateTime          @default(now())

  entries CompetitionEntry[]
}

model CompetitionEntry {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  storyId       String
  story         Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  placement     Int?
  createdAt     DateTime    @default(now())

  @@unique([competitionId, storyId])
}

// Narriva

enum NarrivaSubmissionStatus {
  RECEIVED
  READING
  REVIEWED
  ACCEPTED
  DECLINED
}

// Used by the Author Portal (Phase 8) to show progress after acceptance.
enum NarrivaSubmissionStage {
  SUBMITTED
  EDITORIAL
  DESIGN
  PRODUCTION
  LAUNCHED
}

model NarrivaSubmission {
  id String @id @default(cuid())

  authorName  String
  authorEmail String
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  manuscriptTitle String
  manuscriptRef   String
  synopsis        String?
  targetAudience  String?
  genre           String?
  manuscriptStage String?
  // What kind of support the author thinks they need (developmental
  // editing, line editing, cover design, etc.) — their own guess, not a
  // commitment; the actual plan comes out of our assessment.
  supportNeeded   String[] @default([])

  status        NarrivaSubmissionStatus @default(RECEIVED)
  reviewerNotes String?
  currentStage  NarrivaSubmissionStage?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updates       SubmissionUpdate[]
  authorProject AuthorProject?

  @@index([userId])
  @@index([status])
}

model WriterBankDetails {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  withdrawalRequests WithdrawalRequest[]
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

model WithdrawalRequest {
  id                   String                  @id @default(cuid())
  userId               String
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Decimal so a writer can withdraw their full earned balance even when it
  // isn't a whole number (e.g. 42.7 cowries).
  cowriesAmount        Decimal                 @db.Decimal(10, 2)
  ngnAmount            Float
  bankDetailsId        String
  bankDetails          WriterBankDetails       @relation(fields: [bankDetailsId], references: [id], onDelete: Cascade)
  status               WithdrawalRequestStatus @default(PENDING)
  paystackTransferCode String?
  paystackTransferRef  String?
  adminNote            String?
  rejectionReason      String?
  requestedAt          DateTime                @default(now())
  processedAt          DateTime?

  @@index([userId])
  @@index([status])
}

model PlatformEarnings {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  unlockId  String   @unique
  // The platform's 30% share — the exact remainder after the writer's
  // Decimal share, not necessarily a whole number either.
  cowries   Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([storyId])
}

model StoryReadingProgress {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId        String
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scrollFraction Float    @default(0) // 0.0–1.0
  updatedAt      DateTime @updatedAt

  @@unique([userId, storyId])
}

// One row per user per UTC calendar day they did real reading activity
// (see recordReadingActivity in lib/data/kekere-streaks.ts, called from the
// same reading-progress endpoint StoryReadingProgress uses) — powers the
// profile's reading-streak stat and activity heatmap. `date` is truncated to
// midnight UTC; streaks are computed on UTC day boundaries, not the reader's
// local timezone (not stored anywhere today), so a read right around
// midnight can land on a different day than the reader would expect.
model ReadingActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// Narriva blog (Phase 7) — added here since it didn't exist in the Phase 1
// schema; the mock posts from Phase 6 seed into this model.

enum BlogCategory {
  WRITING_CRAFT
  PUBLISHING_ADVICE
  AUTHOR_SPOTLIGHT
  KEKERE_FEATURE
  BEHIND_THE_SCENES
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id    String @id @default(cuid())
  slug  String @unique
  title String

  excerpt String
  // Stored as lightweight markdown (headings, bold/italic, links) written
  // through the admin's simple rich text editor — see src/lib/utils/markdown.tsx.
  content String

  // No real image pipeline yet — every featured "image" on the site today is
  // a solid colour placeholder block, same as Book/Author. featuredImageRef
  // stays nullable for whenever real asset URLs (R2/CDN) replace this.
  featuredImageRef String?
  coverColor       String       @default("#1E3A8A")
  category         BlogCategory
  tags             String[]
  authorName       String

  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
}

// Service page content (Phase 4/7) — editorial copy, admin-editable since it
// evolves, but stable enough that public pages can render it directly.
model Service {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  content Json
  order   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NariFaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  keywords  String[]
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Manual admin actions worth a paper trail — currently just BookPurchase
model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // e.g. "APPROVE_WITHDRAWAL", "MANUAL_CREDIT"
  target    String?  // user/story/transaction id
  details   Json?
  createdAt DateTime @default(now())
}

model AdminAction {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String
  action       String
  detail       Json?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
}

model NariConversation {
  id           String    @id @default(cuid())
  sessionId    String    @unique
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Full conversation as an array of {role, content, timestamp}.
  messages     Json
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  durationSecs Int?

  intel NariConversationIntel?

  @@index([userId])
  @@index([startedAt])
}

enum IntentLevel {
  HIGH
  MEDIUM
  LOW
  BROWSING
}

model NariConversationIntel {
  id                 String           @id @default(cuid())
  conversationId     String           @unique
  conversation       NariConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  visitorName        String?
  visitorEmail       String?
  manuscriptTopic    String?
  manuscriptStatus   String?
  wordCount          String?
  servicesInterest   String[]
  timelineSignal     String?
  budgetSignal       String?
  painPoints         String?
  competitorMentions String[]
  intentLevel        IntentLevel      @default(LOW)
  extractedAt        DateTime         @default(now())
  leadId             String?
  lead               NariLead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([intentLevel])
}

enum NariLeadStatus {
  NEW
  CONTACTED
  IN_DISCUSSION
  SUBMITTED
  WON
  LOST
}

model NariLead {
  id              String         @id @default(cuid())
  name            String?
  email           String?
  manuscriptTopic String?
  intentLevel     IntentLevel    @default(MEDIUM)
  status          NariLeadStatus @default(NEW)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  conversationIntels NariConversationIntel[]
}

enum ProjectStage {
  ASSESSMENT
  EDITORIAL
  DESIGN
  PRODUCTION
  LAUNCHED
}

model AuthorProject {
  id               String            @id @default(cuid())
  submissionId     String            @unique
  submission       NarrivaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookTitle        String
  coverImageRef    String?
  currentStage     ProjectStage      @default(ASSESSMENT)
  // Bumped whenever currentStage actually changes (see the PUT handler in
  // api/admin/narriva/projects/[projectId]/stage) — lets "days in this
  // stage" be measured from the last real stage transition instead of
  // from project creation.
  stageEnteredAt   DateTime          @default(now())
  // Short admin-written status message shown to the author.
  statusNote       String?
  expectedPubDate  DateTime?
  isbn             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  deliverables ProjectDeliverable[]
  messages     ProjectMessage[]
  documents    ProjectDocument[]
  tasks        ProjectTask[]

  @@index([userId])
  @@index([currentStage])
}

enum DeliverableStatus {
  DRAFT
  FOR_REVIEW
  CHANGES_REQUESTED
  APPROVED
}

model ProjectDeliverable {
  id         String            @id @default(cuid())
  projectId  String
  project    AuthorProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String
  stage      ProjectStage
  status     DeliverableStatus @default(DRAFT)
  // The admin user's name (display string, not a relation).
  uploadedBy String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  versions DeliverableVersion[]
  comments DeliverableComment[]

  @@index([projectId])
  @@index([status])
}

model DeliverableVersion {
  id             String             @id @default(cuid())
  deliverableId  String
  deliverable    ProjectDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  versionNumber  Int
  fileRef        String // R2 path
  fileType       String
  fileSizeBytes  Int?
  uploadedBy     String
  uploadedAt     DateTime           @default(now())

  @@index([deliverableId])
}

model DeliverableComment {
  id            String             @id @default(cuid())
  deliverableId String
  deliverable   ProjectDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  authorId      String
  author        User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorRole    String
  body          String
  // Internal comments are never shown to the author.
  isInternal    Boolean            @default(false)
  isKeyDecision Boolean            @default(false)
  createdAt     DateTime           @default(now())

  @@index([deliverableId])
}

model ProjectMessage {
  id          String        @id @default(cuid())
  projectId   String
  project     AuthorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorRole  String
  body        String
  isInternal  Boolean       @default(false)
  isPinned    Boolean       @default(false)
  pinnedLabel String?
  createdAt   DateTime      @default(now())

  @@index([projectId])
}

model ProjectDocument {
  id         String        @id @default(cuid())
  projectId  String
  project    AuthorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String
  fileRef    String
  fileType   String
  uploadedBy String
  uploadedAt DateTime      @default(now())

  @@index([projectId])
}

enum ProjectTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETE
}

model ProjectTask {
  id          String            @id @default(cuid())
  projectId   String
  project     AuthorProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignedTo  String
  dueDate     DateTime?
  status      ProjectTaskStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([projectId])
}

model BookSale {
  id         String   @id @default(cuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  amountNgn  Float    // price in NGN
  royaltyNgn Float?   // author's share in NGN (80% of amountNgn for platform sales)
  saleType   String   @default("EBOOK") // EBOOK, PRINT
  saleSource String   @default("NARRIVA_PLATFORM") // NARRIVA_PLATFORM, AMAZON, OTHER
  saleDate   DateTime @default(now())

  @@index([bookId])
  @@index([saleDate])
}

model KekereContractTemplate {
  id           String   @id @default(cuid())
  name         String
  contractType String
  // Full contract text with {{variable}} placeholders.
  body         String
  // Names of the variables used in `body`.
  variables    String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contracts KekereContract[]
}

enum KekereContractStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
  VOIDED
}

model KekereContract {
  id            String                  @id @default(cuid())
  templateId    String
  template      KekereContractTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  writerId      String
  writer        User                    @relation(fields: [writerId], references: [id], onDelete: Cascade)
  // When set, signing this contract automatically publishes the linked story.
  storyId       String?
  story         Story?                  @relation(fields: [storyId], references: [id], onDelete: SetNull)
  // Rendered contract with variables substituted.
  body          String
  status        KekereContractStatus    @default(PENDING)
  signedName    String?
  signedAt      DateTime?
  signerIp      String?
  signedPdfRef  String?
  declinedAt    DateTime?
  declineReason String?
  expiresAt     DateTime?
  sentAt        DateTime                @default(now())

  @@index([writerId])
  @@index([storyId])
  @@index([status])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
